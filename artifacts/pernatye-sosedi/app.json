{
  "expo": {
    "name": "Пернатые соседи",
    "slug": "pernatye-sosedi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pernatye-sosedi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8faf8"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.pernatyesosedi.app",
      "versionCode": 18
    },
    "locales": {
      "ru": "./locales/ru.json"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-document-picker",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Приложение использует геолокацию чтобы показывать птичников рядом с вами."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "7b2e521e-1f12-4a60-a545-5441e3fffbbd"
      },
      "yandexMapsApiKey": "$(EXPO_PUBLIC_YANDEX_MAPS_API_KEY)"
    }
  }
}
